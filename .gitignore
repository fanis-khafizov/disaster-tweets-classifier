# === ML project specific ===

# Raw / processed datasets (managed by DVC, located at repo root).
# Track .dvc pointer files but ignore the actual data.
/data/*
!/data/*.dvc
!/data/.gitignore

# Trained model artifacts (managed by DVC).
/artifacts/*
!/artifacts/*.dvc
!/artifacts/.gitignore
